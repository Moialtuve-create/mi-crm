# Copia este archivo a .env.local y rellena los valores.
# Los genera `npx convex dev` (desarrollo) / `npx convex deploy` (producción).

# URL del deployment de Convex (pública, usada por el cliente React)
NEXT_PUBLIC_CONVEX_URL=

# Identificador del deployment de Convex (lo escribe la CLI de Convex)
CONVEX_DEPLOYMENT=

# --- Producción (Railway) ---
# Estas NO van en este archivo: se configuran como variables del servicio en Railway.
#   CONVEX_DEPLOY_KEY  Clave de despliegue de PRODUCCIÓN generada en el dashboard de
#                      Convex (Settings → Deploy keys → Production). El build de Railway
#                      corre `npx convex deploy --cmd 'npm run build'` (ver railway.json),
#                      que despliega las funciones a producción e inyecta
#                      NEXT_PUBLIC_CONVEX_URL en el build automáticamente.
